# Database (Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:6543/postgres
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ARCHIVE_BUCKET=quant-archive
PREDICT_MODEL_SOURCE=mlflow_first

# Daily pipeline — Step 9b DB simulations use model_registry production model_version.
# Set to 1 once to delete existing simulation_runs + paper_trades for that date/model and re-run
# (e.g. after promoting v1.0.709 so sims match PROD).
SIM_FORCE_RERUN=0

# Cache (Upstash Redis)
REDIS_URL=rediss://default:[PASSWORD]@[HOST].upstash.io:6379

# Data Providers
NEWSAPI_KEY=your_newsapi_key
FRED_API_KEY=your_fred_api_key
FINNHUB_API_KEY=your_finnhub_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key  # Free: https://www.alphavantage.co/support/#api-key
SIMFIN_API_KEY=your_simfin_key                # Free: https://simfin.com/

# MLflow (Dagshub)
MLFLOW_TRACKING_URI=https://dagshub.com/[USER]/[REPO].mlflow
MLFLOW_TRACKING_USERNAME=your_dagshub_username
MLFLOW_TRACKING_PASSWORD=your_dagshub_token

# Prefect Cloud
PREFECT_API_KEY=your_prefect_cloud_api_key
PREFECT_API_URL=https://api.prefect.cloud/api/accounts/[ACCOUNT]/workspaces/[WORKSPACE]

# App
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
