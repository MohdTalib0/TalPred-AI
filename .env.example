# Database (Supabase)
# GitHub Actions / CI: use Transaction pooler — NOT db.*.supabase.co (that host is IPv6-only on runners).
# Dashboard: Project Settings → Database → Connection string → URI → Transaction pooler
# (host: aws-0-<region>.pooler.supabase.com:6543, user: postgres.<project-ref>)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ARCHIVE_BUCKET=quant-archive
PREDICT_MODEL_SOURCE=mlflow_first

# Daily pipeline — Step 9b DB simulations use model_registry production model_version.
# Set to 1 once to delete existing simulation_runs + paper_trades for that date/model and re-run
# (e.g. after promoting v1.0.709 so sims match PROD).
SIM_FORCE_RERUN=0

# Fundamentals (CLI --step 11): bulk upsert to fundamental_features (Mondays).
# In GitHub Actions, ingest is skipped unless FUNDAMENTALS_INGEST_IN_CI=1 (see fundamentals-pipeline.yml).
FUNDAMENTALS_INGEST_IN_CI=0
# Optional: run fundamentals on a non-Monday (local/CI recovery).
# FUNDAMENTALS_FORCE_RUN=0
# Optional: calendar for "is it Monday?" (e.g. America/New_York). Unset = local time locally, UTC in Actions.
# PIPELINE_CALENDAR_TZ=UTC
FUNDAMENTAL_LOOKBACK_YEARS=2

# Cache (Upstash Redis)
REDIS_URL=rediss://default:[PASSWORD]@[HOST].upstash.io:6379

# Data Providers
NEWSAPI_KEY=your_newsapi_key
FRED_API_KEY=your_fred_api_key
FINNHUB_API_KEY=your_finnhub_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key  # Free: https://www.alphavantage.co/support/#api-key
SIMFIN_API_KEY=your_simfin_key                # Free: https://simfin.com/

# MLflow (Dagshub)
MLFLOW_TRACKING_URI=https://dagshub.com/[USER]/[REPO].mlflow
MLFLOW_TRACKING_USERNAME=your_dagshub_username
MLFLOW_TRACKING_PASSWORD=your_dagshub_token

# Prefect Cloud
PREFECT_API_KEY=your_prefect_cloud_api_key
PREFECT_API_URL=https://api.prefect.cloud/api/accounts/[ACCOUNT]/workspaces/[WORKSPACE]

# App
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
